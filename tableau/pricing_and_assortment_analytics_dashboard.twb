      <aliases enabled='yes' />
      <column caption='Is On Promo' datatype='boolean' name='[Calculation_2185340985012224]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT ISNULL([promo_price])' />
      </column>
      <column caption='Discount Pct (Clean)' datatype='real' name='[Calculation_2185340985135105]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF NOT ISNULL([discount_pct]) THEN [discount_pct] ELSE 0 END' />
      </column>
      <column caption='Price Tier' datatype='string' name='[Calculation_2185340985331714]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [price_per_unit] &lt; 0.10 THEN &quot;Budget&quot; ELSEIF [price_per_unit] &lt; 0.30 THEN &quot;Mid&quot; ELSE &quot;Premium&quot; END' />
      </column>
      <column caption='Private Label Flag' datatype='string' name='[Calculation_2185340985397251]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [brand] = &quot;Harris Teeter&quot; OR [brand] = &quot;Simple Truth&quot; OR [brand] = &quot;Simple Truth Organic&quot; OR [brand] = &quot;Private Selection&quot; OR [brand] = &quot;HT Traders&quot; THEN &quot;Private Label&quot; ELSE &quot;National Brand&quot; END' />
      </column>
      <column caption='Availability (Int)' datatype='integer' name='[Calculation_2185340985479172]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([availability])' />
      </column>
      <column caption='On Promo %' datatype='real' name='[Calculation_2384352786026497]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(INT([Calculation_2185340985012224])) / COUNT([product_id])' />
      </column>
      <column caption='High Stock %' datatype='real' name='[Calculation_2384352786464770]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [stock_level] = &quot;HIGH&quot; THEN 1 ELSE 0 END) / COUNT([product_id])' />
      </column>
      <column caption='NA HEATMAP' datatype='string' name='[Calculation_2478910944321536]' role='measure' type='nominal'>
